rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /proofs/{allPaths=**} {
      // Allow public write for booking proofs, but only admin can read all
      allow write: if true;
      allow read: if request.auth != null;
    }
    match /assets/{allPaths=**} {
      // Allow admin to manage app assets like logo
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
