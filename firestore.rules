rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'court', 'timeSlots', 'status', 'timestamp'])
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && data.court in ['Court 1', 'Court 2']
        && data.timeSlots is list && data.timeSlots.size() > 0 && data.timeSlots.size() <= 24
        && data.status in ['confirmed', 'blocked']
        && data.timestamp is number;
    }

    match /bookings/{bookingId} {
      allow read: if true; // Public can see booked slots to avoid conflict
      allow create: if isValidBooking(request.resource.data) && isValidId(bookingId);
      allow update, delete: if isSignedIn(); // Add admin check if possible, but for now simple auth
    }
  }
}
